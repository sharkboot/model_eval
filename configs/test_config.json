{
  "model": {
    "type": "local",
    "name": "LocalModel",
    "config": {
      "model_name": "bert-base-chinese",
      "device": "cpu"
    }
  },
  "dataset": {
    "type": "custom",
    "name": "MCQDataset",
    "config": {
      "data_path": "data/mcq_sample.json",
      "split": "test"
    }
  },
  "backend": {
    "type": "native",
    "name": "NativeBackend",
    "config": {
      "task_type": "llm"
    }
  },
  "performance": {
    "type": "concurrency",
    "name": "ConcurrencyTest",
    "config": {
      "concurrency": 2,
      "requests": 10
    }
  },
  "report": {
    "type": "table",
    "name": "TableReport",
    "config": {
      "output_path": "results/test_eval_results.csv"
    }
  },
  "visualization": {
    "type": "gradio",
    "name": "GradioVisualizer",
    "config": {
      "share": true
    }
  }
}
